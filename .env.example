# No required env vars — Docker socket is reached via the socket-proxy service

# Background metrics sampling, in seconds.
#   30 (default) → record history continuously, even with no dashboard open
#   0            → sample on demand only (no load while idle)
SAMPLE_INTERVAL=30

# API token validation (leave empty to skip)
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
GROQ_API_KEY=
TAVILY_API_KEY=
GITLAB_TOKEN=
GITLAB_HOST=gitlab.com
